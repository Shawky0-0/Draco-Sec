# Copy this file to .env and fill in values
# SECRET_KEY used for JWT signing — change this in production!
SECRET_KEY=dracosec-super-secret-key-change-in-prod

# VirusTotal API Key (required for scan features)
VT_API_KEY=your_virustotal_api_key_here

# GoPhish API Key (optional, for phishing simulation)
GOPHISH_API_URL=http://localhost:3333
GOPHISH_API_KEY=your_gophish_api_key_here
